<Window x:Class="ModbusDataReceiver.WaitingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="请稍候" 
        Width="400" 
        Height="150" 
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border Background="Transparent">
        <!-- 外发光效果 -->
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" 
                              BlurRadius="20" 
                              Color="#FF0078D7" 
                              Opacity="0.8"/>
        </Border.Effect>

        <Border Background="White" 
                CornerRadius="10" 
                BorderBrush="#0078D7" 
                BorderThickness="2"
                Margin="15">

            <!-- 内阴影效果 -->
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" 
                                  BlurRadius="10" 
                                  Color="#0078D7" 
                                  Opacity="0.3"
                                  Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 主要内容 -->
                <StackPanel Grid.Row="1" 
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="20">

                    <!-- 加载动画 -->
                    <Border Width="40" 
                           Height="40"
                           BorderBrush="#0078D7"
                           BorderThickness="2"
                           CornerRadius="20"
                           Margin="0,0,15,0">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:1" 
                                            RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Border.RenderTransform>
                            <RotateTransform CenterX="20" CenterY="20"/>
                        </Border.RenderTransform>

                        <!-- 旋转指示器 -->
                        <Path Data="M10,0 L10,10 L20,5 Z" 
                             Fill="#0078D7"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Margin="10,0,0,0"/>
                    </Border>

                    <!-- 状态文本 -->
                    <StackPanel Orientation="Vertical"
                               VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" 
                                  Text="正在将配置文件的数据下载到控制器..." 
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Foreground="#333333"
                                  TextWrapping="Wrap"
                                  MaxWidth="280"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>