<Window x:Class="ModbusDataReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="电机控制系统软件专业版2025" Height="800" Width="1400" 
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="2,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2,1" />

            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="18" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
        <Style x:Key="ValueTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5,3" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5,3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Height" Value="24" />
        </Style>

        <!-- 定义颜色资源 -->
        <SolidColorBrush x:Key="CurrentColor" Color="#FFA0FBFF"/>
        <!-- 电流相关 - 浅蓝色 -->
        <SolidColorBrush x:Key="VoltageColor" Color="#FFB1FFA0"/>
        <!-- 电压相关 - 浅绿色 -->
        <SolidColorBrush x:Key="TemperatureColor" Color="#FFE1F5FE"/>
        <!-- 温度相关 - 浅粉色 -->
        <SolidColorBrush x:Key="ControlColor" Color="#FFF3E5F5"/>
        <!-- 控制相关 - 浅紫色 -->
        <SolidColorBrush x:Key="StatusColor" Color="#FFFFF8E1"/>
        <!-- 状态相关 - 浅黄色 -->
        <SolidColorBrush x:Key="FaultColor" Color="#FF9171FF"/>
        <!-- 故障相关 - 浅棕色 -->
        <SolidColorBrush x:Key="SignalColor" Color="#FFE8EAF6"/>
        <!-- 信号相关 - 浅靛蓝色 -->
        <SolidColorBrush x:Key="SystemColor" Color="#FFD2D2D2"/>

        <!-- 系统相关 - 浅青色 -->
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="484*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Menu VerticalAlignment="Top">
                <!-- File 菜单 -->
                <MenuItem Header="文件">
                    <MenuItem Header="加载配置文件(.json)" Click="LoadConfigButton_Click"/>
                    <MenuItem Header="保存配置文件(.json)" Click="SaveConfigButton_Click"/>
                </MenuItem>
                <MenuItem Header="刷机">
                    <MenuItem Header="固件升级" Click="GuJianShenJi_Click"/>
                </MenuItem>
                <MenuItem Header="帮助">
                    <MenuItem Header="关于" Click="AboutMenuItem_Click"/>
                    <MenuItem Header="联系我们" Click="ContactMenuItem_Click"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- 顶部控制栏 -->
        <Border Grid.Row="1" Background="#FFB5B5B5" BorderBrush="#FFAAAAAA" Padding="8" Grid.ColumnSpan="2" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                <TextBlock Text="串口:" VerticalAlignment="Center"/>
                <ComboBox x:Name="ComPortComboBox" Width="80" SelectionChanged="ComPortComboBox_SelectionChanged"/>

                <TextBlock Text="波特率:" Margin="15,0,0,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="BaudRateComboBox" Width="80" SelectedIndex="5">
                    <ComboBoxItem>9600</ComboBoxItem>
                    <ComboBoxItem>14400</ComboBoxItem>
                    <ComboBoxItem>19200</ComboBoxItem>
                    <ComboBoxItem>38400</ComboBoxItem>
                    <ComboBoxItem>57600</ComboBoxItem>
                    <ComboBoxItem>115200</ComboBoxItem>
                </ComboBox>

                <Button x:Name="btnRefreshCom" Margin="15,0,0,0" Click="Button_Click_RefreshCom" Content="刷新串口"/>
                
                <Button x:Name="ConnectButton" Content="打开串口" Click="ConnectButton_Click" Margin="15,0,0,0" Background="#FFD2D2D2" Foreground="Black"/>

                <Button x:Name="ReadControllerDataButton" Content="读取控制器数据" Click="ReadControllerDataButton_Click" Margin="15,0,0,0" Background="#FFD2D2D2" Foreground="Black"/>

                <Button x:Name="DownloadToControllerButton" Content="下载数据到控制器" Click="DownloadToControllerButton_Click" Margin="15,0,0,0" Background="#FFD2D2D2" Foreground="Black"/>

                <Button x:Name="SendDataButton" Content="开始接收" Click="ReceiveDataButton_Click" Margin="15,0,0,0" Background="Green" Foreground="White"/>

                <TextBlock Text="接收帧数:" Margin="20,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="FrameCountTextBox" Width="60" Text="0" Background="White" IsReadOnly="True"/>

                <TextBlock Text="发送帧数:" Margin="15,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="SendFrameCountTextBox" Width="60" Text="0" Background="White"/>

                <TextBlock Text="状态:" Margin="15,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="StatusTextBox" Width="200" Text="未连接" Background="White"/>

                <TextBlock Text="最后更新:" Margin="15,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="LastUpdateText" Width="80" Text="--:--:--" Background="White"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" Margin="0,0,719,0" VerticalAlignment="Top" Height="237" Background="#FFB5B5B5" Width="681" HorizontalAlignment="Left">
            <Border HorizontalAlignment="Left" Margin="0,5,0,0" VerticalAlignment="Top">
                <Grid>
                    <!-- 第1列 - 电压参数 -->
                    <StackPanel Grid.Column="0" Margin="2,2,0,2">
                        <TextBlock Text="母线电压"/>
                        <TextBox x:Name="UdcActTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="输出电压"/>
                        <TextBox x:Name="UsOutTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="刹车电压"/>
                        <TextBox x:Name="BrakeVoltFiltedTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="油门电压"/>
                        <TextBox x:Name="ThrottleVoltFiltedTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="直流电流"/>
                        <TextBox x:Name="IdcFilterTextBox" Background="{StaticResource CurrentColor}"/>
                        <TextBlock Text="弱磁电流"/>
                        <TextBox x:Name="WeakenCurtTextBox" Background="{StaticResource CurrentColor}"/>
                    </StackPanel>

                    <!-- 第2列 - 电流相关 -->
                    <StackPanel Margin="67,2,-65,2">
                        <TextBlock Text="U相电流"/>
                        <TextBox x:Name="IuActTextBox" Background="{StaticResource CurrentColor}"/>
                        <TextBlock Text="V相电流"/>
                        <TextBox x:Name="IvActTextBox" Background="{StaticResource CurrentColor}"/>
                        <TextBlock Text="W相电流"/>
                        <TextBox x:Name="IwActTextBox" Background="{StaticResource CurrentColor}"/>
                        <TextBlock Text="调制系数"/>
                        <TextBox x:Name="ModulaionCoeffTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="D轴电流"/>
                        <TextBox x:Name="IdFbTextBox" Background="{StaticResource CurrentColor}"/>
                        <TextBlock Text="Q轴电流"/>
                        <TextBox x:Name="IqFbTextBox" Background="{StaticResource CurrentColor}"/>


                    </StackPanel>

                    <!-- 第3列 - 控制相关 -->
                    <StackPanel Margin="132,2,-130,2">

                        <TextBlock Text="电机温度1"/>
                        <TextBox x:Name="MtrT1TextBox" Background="{StaticResource TemperatureColor}"/>
                        <TextBlock Text="电机温度2"/>
                        <TextBox x:Name="MtrT2TextBox" Background="{StaticResource TemperatureColor}"/>
                        <TextBlock Text="MOS温度"/>
                        <TextBox x:Name="PwrMdlUTTextBox" Background="{StaticResource TemperatureColor}"/>
                        <TextBlock Text="PWM周期"/>
                        <TextBox x:Name="PwmTsTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="速度命令"/>
                        <TextBox x:Name="SpdCmdTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="电机转速"/>
                        <TextBox x:Name="MtrSpdTextBox" Background="{StaticResource SystemColor}"/>
                    </StackPanel>

                    <!-- 第4列 - 扭矩控制 -->
                    <StackPanel Margin="197,2,-195,2">
                        <TextBlock Text="驱动扭矩"/>
                        <TextBox x:Name="DriveTrqTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="回收扭矩"/>
                        <TextBox x:Name="KERS_TrqTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="最大扭矩"/>
                        <TextBox x:Name="TrqAbleMaxTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="最小扭矩"/>
                        <TextBox x:Name="TrqAbleMinTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="扭矩命令"/>
                        <TextBox x:Name="TrqCmdTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="扭矩估算值"/>
                        <TextBox x:Name="TrqEstTextBox" Background="{StaticResource SystemColor}"/>

                    </StackPanel>

                    <!-- 第5列 - 前馈电压和电感 -->
                    <StackPanel Margin="262,2,-260,2">
                        <TextBlock Text="逆变模式"/>
                        <TextBox x:Name="InvModeTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="控制模式"/>
                        <TextBox x:Name="CtrlModeTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="D轴前馈"/>
                        <TextBox x:Name="UdFfdTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="Q轴前馈"/>
                        <TextBox x:Name="UqFfdTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="D轴电感"/>
                        <TextBox x:Name="LdTextBox" Background="{StaticResource StatusColor}"/>
                        <TextBlock Text="Q轴电感"/>
                        <TextBox x:Name="LqTextBox" Background="{StaticResource StatusColor}"/>


                    </StackPanel>

                    <!-- 第6列 - 温度相关 -->
                    <StackPanel Margin="327,2,-325,2">
                        <TextBlock Text="整车模式"/>
                        <TextBox x:Name="SigOptModReqTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="运动模式"/>
                        <TextBox x:Name="GearTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="D轴命令"/>
                        <TextBox x:Name="IdCmdTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="Q轴命令"/>
                        <TextBox x:Name="IqCmdTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="D轴电压"/>
                        <TextBox x:Name="PidUdTextBox" Background="{StaticResource VoltageColor}"/>
                        <TextBlock Text="Q轴电压"/>
                        <TextBox x:Name="PidUqTextBox" Background="{StaticResource VoltageColor}"/>


                    </StackPanel>

                    <!-- 第8列 - 系统状态 -->
                    <StackPanel Margin="392,2,-390,2">
                        <TextBlock Text="电机状态"/>
                        <TextBox x:Name="MtrStsTextBox" Background="{StaticResource StatusColor}"/>
                        <TextBlock Text="ASC状态"/>
                        <TextBox x:Name="AscStsTextBox" Background="{StaticResource StatusColor}"/>
                        <TextBlock Text="磁编状态"/>
                        <TextBox x:Name="AglSdyStsTextBox" Background="{StaticResource StatusColor}"/>
                        <TextBlock Text="磁链"/>
                        <TextBox x:Name="FluxTextBox" Background="{StaticResource StatusColor}"/>
                        <TextBlock Text="限功率系数"/>
                        <TextBox x:Name="PwrLimKTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="ISR负载率"/>
                        <TextBox x:Name="IsrLoadRatioTextBox" Background="{StaticResource SystemColor}"/>

                    </StackPanel>

                    <!-- 第9列 - 输入信号 -->
                    <StackPanel Margin="457,2,-455,2">
                        <TextBlock Text="钥匙开关"/>
                        <TextBox x:Name="KeySwitchTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="刹车信号"/>
                        <TextBox x:Name="BrakeSigTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="油门开度"/>
                        <TextBox x:Name="ThrottleOpeningTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="刹车开度"/>
                        <TextBox x:Name="BrakeOpeningTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="三速档位"/>
                        <TextBox x:Name="ThreeGearSigTextBox" Background="{StaticResource SignalColor}"/>
                        <TextBlock Text="总负载率"/>
                        <TextBox
                            Background="{StaticResource SystemColor}" x:Name="AllLoadRatioTextBox"/>
                    </StackPanel>

                    <!-- 第7列 - 错误状态 -->
                    <StackPanel Margin="522,2,-520,2">
                        <TextBlock Text="错误编号"/>
                        <TextBox x:Name="ErrNumTextBox" Background="{StaticResource FaultColor}"/>
                        <TextBlock Text="错误等级"/>
                        <TextBox x:Name="ErrRnkTextBox" Background="{StaticResource FaultColor}"/>
                        <TextBlock Text="错误总和"/>
                        <TextBox x:Name="ErrSumTextBox" Background="{StaticResource FaultColor}"/>
                        <TextBlock Text="油门故障"/>
                        <TextBox x:Name="ThrottleFailTextBox" Background="{StaticResource FaultColor}"/>
                        <TextBlock Text="刹车故障"/>
                        <TextBox x:Name="BrakeFailTextBox" Background="{StaticResource FaultColor}"/>
                        <TextBlock Text="信号故障"/>
                        <TextBox x:Name="SignalFailTextBox" Background="{StaticResource FaultColor}"/>
                    </StackPanel>

                    <!-- 第10列 - 系统信息 -->
                    <StackPanel Margin="587,2,-601,2">
                        <TextBlock Text="协议状态"/>
                        <TextBox x:Name="ProcotolUsedTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="日期代码"/>
                        <TextBox x:Name="DateCodeTextBox" Background="{StaticResource SystemColor}"/>
                        <TextBlock Text="项目代码"/>
                        <TextBox x:Name="MdlPrjCodeTextBox" Background="{StaticResource SystemColor}"/>
                    </StackPanel>

                </Grid>
            </Border>
        </Border>

        <TabControl Grid.Row="2" Margin="0,237,0,27" x:Name="MainTabControl" Grid.RowSpan="2">
        </TabControl>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="3" Background="#FFE3F2FD" Margin="0,5,0,0" Grid.ColumnSpan="2">
            <StatusBarItem x:Name="StatusBarText">
                <TextBlock x:Name="StatusText" Text="就绪" FontWeight="SemiBold"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="电机控制系统软件专业版2025-上海盘毂动力科技股份有限公司出品" FontStyle="Italic" Foreground="#FF666666"/>
            </StatusBarItem>
        </StatusBar>
        <Border x:Name="ParameterBorder" Grid.Row="1" Margin="681,52,0,0" Grid.RowSpan="2" Height="232" VerticalAlignment="Top">
            <Grid Margin="10,0,0,10" MaxHeight="230">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 控制面板 -->
                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="Gray" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Margin="5,3" VerticalAlignment="Center">
                        <TextBlock Text="观测参数:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                        <ComboBox x:Name="ChartParameterComboBox" Width="120" FontSize="11" Height="22" SelectedIndex="1" SelectionChanged="ChartParameterComboBox_SelectionChanged"/>

                        <TextBlock Text="时间范围:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                        <ComboBox x:Name="TimeRangeComboBox" Width="60" FontSize="11" Height="22" SelectedIndex="1" SelectionChanged="TimeRangeComboBox_SelectionChanged">
                            <ComboBoxItem>10秒</ComboBoxItem>
                            <ComboBoxItem>20秒</ComboBoxItem>
                            <ComboBoxItem>30秒</ComboBoxItem>
                        </ComboBox>

                        <Button x:Name="ClearChartButton" Content="清除" Click="ClearChartButton_Click" 
                        Margin="5,0,0,0" Padding="8,2" FontSize="11" Height="22"/>

                        <TextBlock x:Name="ChartStatusText" Margin="10,0,5,0" VerticalAlignment="Center" 
                          FontSize="11" FontWeight="Bold" Foreground="DarkBlue"/>
                    </StackPanel>
                </Border>

                <!-- 图表显示区域 -->
                <lvc:CartesianChart Grid.Row="1" x:Name="LiveChart" Margin="5" 
                           Hoverable="False" DataTooltip="{x:Null}" DisableAnimations="True"
                           Zoom="Xy" Pan="Xy">
                    <lvc:CartesianChart.Series>
                        <lvc:LineSeries x:Name="ChartSeries" 
                               Values="{Binding ChartValues}"
                               Title="实时数据"
                               PointGeometry="{x:Null}"
                               LineSmoothness="0"
                               StrokeThickness="2"
                               Stroke="Blue"
                               Fill="Transparent"/>
                    </lvc:CartesianChart.Series>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis x:Name="XAxis"
                          LabelFormatter="{Binding XFormatter}"
                          FontSize="10">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="10"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis x:Name="YAxis" Title="数值" 
                          LabelFormatter="{Binding YFormatter}"
                          FontSize="10"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</Window>