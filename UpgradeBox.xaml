<Window x:Class="ModbusDataReceiver.UpgradeBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="固件升级"
        Width="450"
        Height="230"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        mc:Ignorable="d">

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 文件信息 -->
        <Grid Grid.Row="0" Margin="10,10,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="文件:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
            <TextBlock x:Name="txtFileName" Grid.Column="1" Text="" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
        </Grid>

        <Grid Grid.Row="1" Margin="10,5,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="大小:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
            <TextBlock x:Name="txtFileSize" Grid.Column="1" Text="" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="12"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="10,10,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="进度:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
            <ProgressBar x:Name="progressBar1" Grid.Column="1" Height="18" Margin="5,0,5,0" Minimum="0"/>
            <TextBlock x:Name="txtProgressPercent" Grid.Column="2" Text="0%" Width="40" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
        </Grid>

        <!-- 传输状态 -->
        <Grid Grid.Row="3" Margin="10,5,10,5" Height="50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="状态:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
            <TextBlock x:Name="txtStatus" Grid.Column="1" Text="等待连接..." Margin="5,0,10,0" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 关闭按钮 -->
        <Grid Grid.Row="4" Margin="10,10,10,10">
            <Button x:Name="btnClose" Content="关闭" HorizontalAlignment="Right" Width="80" Height="25" 
                    IsEnabled="False" Click="btnClose_Click" FontSize="12"/>
        </Grid>
    </Grid>
</Window>